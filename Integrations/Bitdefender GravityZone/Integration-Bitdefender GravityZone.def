    "IntegrationSupportedActions": [
        {
            "Name": "Reports - List All",
            "Description": "This method returns the list of scheduled reports, according to the parameters received.",
            "Id": 940,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Reports - Get Download Links",
            "Description": "This method returns an Object with information regarding the report availability for download and the corresponding download links.\nThe instant report is created one time only and available for download for less than 24 hours.\nScheduled reports are generated periodically and all report instances are saved in the GravityZone database.",
            "Id": 941,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Restore Isolated Endpoint",
            "Description": "This method creates a task to restore the specified endpoint from isolation.",
            "Id": 947,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Quarantine - Restore Exchange Items",
            "Description": "This method creates a new task to restore items from the quarantine for Exchange Servers.",
            "Id": 942,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Get Network Inventory Items",
            "Description": "This method returns network inventory items. Note - Some filters require a specific license to be active, otherwise they are ignored, resulting in an inaccurate API response. The field name works with partial matching.\nThe filter returns the items whose names are exact match or start with the specified value. To use the specified value as a suffix, use the asterisk symbol (*).",
            "Id": 943,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Get Hourly Usage for EC2 Instances",
            "Description": "This method exposes the hourly usage for each Amazon instance category (micro, medium etc.).",
            "Id": 944,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Blocklist - Remove Item",
            "Description": "This method removes an item from the Blocklist, identified by its ID",
            "Id": 945,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Set Endpoint Label",
            "Description": "This method sets a new label to an endpoint.",
            "Id": 946,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Quarantine - Restore Items",
            "Description": "This method creates a new task to restore items from the quarantine.\n",
            "Id": 948,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Quarantine - Get Items List",
            "Description": "This method retrieves the list of quarantined items available for a company. An item can be a file or an Microsoft Exchange object.\nThe filter fields Threat Name, File Path, and IP Address work with partial matching.\nThe filter returns the items which are exact match or start with the specified value.\nTo use the specified value as a suffix, use the asterisk symbol (*). For example:\nIf filePath is C:\\temp, the API returns all items originating from this folder, including sub-folders.\nIf filePath is *myfile.exe, then the API returns a list of all myfile.exe files from anywhere on the system.\nThe Exchange filters require a valid license key for Security for Exchange.",
            "Id": 949,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Quarantine - Remove Items",
            "Description": "This method creates a new task to remove items from quarantine.",
            "Id": 950,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
        {
            "Name": "Blocklist - Add Hashes",
            "Description": "Use this method to add one or more file hashes to the Blocklist. Hashes supported: SHA256, MD5.",
            "Id": 951,
            "CreationTimeUnixTimeInMs": 1779092396463,
            "ModificationTimeUnixTimeInMs": 1779092396463
        },
